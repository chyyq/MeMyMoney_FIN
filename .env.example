# Copy this file to .env and fill in the keys you want to enable.
# The app works with sample data when keys are empty.

PORT=5177

# Market and news data
# Alpha Vantage docs: https://www.alphavantage.co/documentation/
ALPHA_VANTAGE_API_KEY=

# Twelve Data docs: https://twelvedata.com/docs
TWELVE_DATA_API_KEY=

# X API v2 bearer token
# X docs: https://developer.x.com/en/docs/twitter-api
X_BEARER_TOKEN=
SERENITY_X_ACCOUNT=Serenity

# YouTube Data API v3
# YouTube docs: https://developers.google.com/youtube/v3/getting-started
YOUTUBE_API_KEY=

# Comma-separated source handles/channels/search phrases.
X_ACCOUNTS=Serenity,unusual_whales,zerohedge,StockMKTNewz
YOUTUBE_QUERIES=market open today,stock market analysis today,AI stocks NVDA today
WATCHLIST=NVDA,MSFT,AMD,ARM,PLTR,TSLA,SOXL,TQQQ,TSLL,QQQ,SPY
